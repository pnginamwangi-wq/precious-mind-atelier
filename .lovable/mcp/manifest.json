{
  "version": 1,
  "sdk_version": "0.21.0",
  "path": "/mcp",
  "auth": {
    "type": "none"
  },
  "mcp": {
    "server": {
      "name": "precious-intelligence-academy-mcp",
      "version": "0.1.0",
      "title": "The Precious Intelligence Academy"
    },
    "tools": [
      {
        "name": "list_journal_articles",
        "title": "List Journal articles",
        "description": "List published articles in The Journal (title, slug, dek, category, tags, reading minutes, published date). Optionally filter by category slug or tag.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "category": {
              "description": "Optional category slug filter, e.g. 'gemstones'.",
              "type": "string"
            },
            "tag": {
              "description": "Optional tag filter (exact match, case insensitive).",
              "type": "string"
            }
          }
        },
        "outputSchema": null
      },
      {
        "name": "get_journal_article",
        "title": "Get a Journal article",
        "description": "Return the full body of a single Journal article by slug, including metadata and structured content blocks.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "slug": {
              "type": "string",
              "minLength": 1,
              "description": "Article slug, e.g. 'four-cs'."
            }
          },
          "required": [
            "slug"
          ]
        },
        "outputSchema": null
      },
      {
        "name": "list_library_items",
        "title": "List Product Library items",
        "description": "List reference objects in the Academy's Product Library (name, slug, summary). These are illustrative pieces used for study, not merchandise for sale.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {}
        },
        "outputSchema": null
      },
      {
        "name": "get_library_item",
        "title": "Get a Product Library item",
        "description": "Return the full description of a single Product Library item by slug, including specifications and educational notes.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "slug": {
              "type": "string",
              "minLength": 1,
              "description": "Library item slug, e.g. 'gold-bar'."
            }
          },
          "required": [
            "slug"
          ]
        },
        "outputSchema": null
      },
      {
        "name": "list_institutes",
        "title": "List Institutes",
        "description": "List the Academy's Institutes (disciplines of study), each with its slug, name, tag, overline, and short introduction.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {}
        },
        "outputSchema": null
      },
      {
        "name": "get_institute",
        "title": "Get an Institute",
        "description": "Return the full public description of an Institute by slug, including philosophy, curriculum outline, practitioner roles, and outcomes.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "slug": {
              "type": "string",
              "minLength": 1,
              "description": "Institute slug, e.g. 'gemstones'."
            }
          },
          "required": [
            "slug"
          ]
        },
        "outputSchema": null
      },
      {
        "name": "search_glossary",
        "title": "Search the Glossary",
        "description": "Search the Academy's glossary of luxury and precious materials terminology. Returns matching entries with their definitions.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "query": {
              "type": "string",
              "minLength": 1,
              "description": "Term or fragment to search for (case insensitive, matches term or definition)."
            }
          },
          "required": [
            "query"
          ]
        },
        "outputSchema": null
      }
    ]
  }
}
